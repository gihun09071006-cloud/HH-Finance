# ── 배포 지갑 ────────────────────────────────────────────────────────────────
# Sepolia ETH가 있는 배포자 지갑 private key (0x 포함)
DEPLOYER_PRIVATE_KEY=0x...

# ── 서비스 지갑 주소 (주소만, private key 불필요) ───────────────────────────
DEV_WALLET=0x...         # 패널티 30% 수령, keeper 권한
EVENT_WALLET=0x...       # 패널티 70% 수령
FEE_RECEIVER=0x...       # 입출금 수수료 수령

# ── RPC ──────────────────────────────────────────────────────────────────────
# Alchemy 또는 Infura Sepolia RPC URL
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── Etherscan 검증 ────────────────────────────────────────────────────────────
# https://etherscan.io/myapikey
ETHERSCAN_API_KEY=...

# ── Chainlink VRF v2.5 ───────────────────────────────────────────────────────
# https://vrf.chain.link/sepolia 에서 구독 생성 후 ID 입력
VRF_SUBSCRIPTION_ID=0
