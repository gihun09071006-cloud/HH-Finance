# ── 배포 지갑 ────────────────────────────────────────────────────────────────
# BNB (가스비)가 있는 배포자 지갑 private key (0x 포함)
DEPLOYER_PRIVATE_KEY=0x...

# ── 서비스 지갑 주소 ──────────────────────────────────────────────────────────
DEV_WALLET=0x...           # 패널티 30% 수령, keeper 권한
EVENT_WALLET=0x...         # 패널티 70% 수령
FEE_RECEIVER=0x...         # 입출금 수수료 수령 (2.5%)

# ── BNB Chain RPC ─────────────────────────────────────────────────────────────
# 테스트넷 (체인ID: 97) — 기본값 사용 가능, 느리면 Alchemy/QuickNode로 교체
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# 메인넷 (체인ID: 56)
BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org/

# ── BscScan 검증 ──────────────────────────────────────────────────────────────
# https://bscscan.com/myapikey
BSCSCAN_API_KEY=...

# ── Chainlink VRF v2.5 ───────────────────────────────────────────────────────
# 테스트넷: https://vrf.chain.link/bsc-testnet
# 메인넷:   https://vrf.chain.link/bsc
# 구독 생성 후 나오는 ID 입력 (LINK 충전 필요)
VRF_SUBSCRIPTION_ID=0
